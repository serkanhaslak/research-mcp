# Cloudflare Workers bindings and vars are defined in `wrangler.toml`.
# This file is only a local reference for values you may want to override in dev.

# External API keys
SERPER_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
SCRAPEDO_API_KEY=
OPENROUTER_API_KEY=

# Optional OpenRouter override
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional model overrides
# RESEARCH_MODEL=x-ai/grok-4.1-fast
# RESEARCH_FALLBACK_MODEL=google/gemini-2.5-flash
# LLM_EXTRACTION_MODEL=minimax/minimax-m2.7
# LLM_EXTRACTION_FALLBACK_MODEL=@cf/openai/gpt-oss-120b

# Optional runtime tuning
# DEFAULT_REASONING_EFFORT=high
# DEFAULT_MAX_URLS=100
# API_TIMEOUT_MS=300000

# Public Worker metadata
# SERVER_NAME=research-mcp
# SERVER_VERSION=5.0.0
# MCP_PROTOCOL_VERSION=2025-11-25
# SESSION_TTL_SECONDS=2592000
