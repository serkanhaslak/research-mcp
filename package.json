{
  "name": "research-mcp",
  "version": "5.0.0",
  "private": true,
  "description": "Private MCP research service on Cloudflare Workers with capability-URL auth and Streamable HTTP transport.",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --env=\"\"",
